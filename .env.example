# ============================================================================
# Variables d'environnement de Kira — COPIE ce fichier en .env et remplis-le.
# Le vrai .env n'est JAMAIS commité (voir .gitignore).
# ============================================================================

# --- Choix du backend du moteur de raisonnement -----------------------------
# anthropic (défaut, API Claude) | ollama (local, expérimental) | mock (tests)
KIRA_BACKEND=anthropic

# Modèle à utiliser (optionnel ; défaut raisonnable par backend).
#   anthropic : claude-sonnet-4-6 (défaut) | claude-opus-4-8 | claude-haiku-4-5-20251001
#   ollama    : llama3.2:3b (défaut)
KIRA_MODEL=

# --- Backend Anthropic ------------------------------------------------------
# Clé API Claude. Obligatoire si KIRA_BACKEND=anthropic.
# Récupère-la sur https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Backend Ollama (optionnel) ---------------------------------------------
# Hôte du serveur Ollama local.
OLLAMA_HOST=http://localhost:11434
